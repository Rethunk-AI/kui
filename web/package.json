{
  "name": "kui-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "a11y": "pa11y http://localhost:4173/ --runner axe",
    "a11y:gha": "pa11y http://localhost:4173/ --runner axe -c pa11y.ci.json",
    "a11y:ci": "start-server-and-test preview http-get://localhost:4173 a11y:gha",
    "a11y:check": "yarn run build && yarn run a11y:ci"
  },
  "dependencies": {
    "@novnc/novnc": "^1.6.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "winbox": "0.2.82"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "happy-dom": "^20.8.9",
    "pa11y": "^9.1.1",
    "postcss": "^8.5.9",
    "start-server-and-test": "^3.0.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "resolutions": {
    "axios": "^1.15.0",
    "basic-ftp": "^5.2.2",
    "lodash": "^4.18.0",
    "vite": "^8.0.8"
  },
  "packageManager": "yarn@4.13.0"
}
