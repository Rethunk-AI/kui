{
  "name": "kui-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "a11y": "pa11y http://localhost:4173/ --runner axe",
    "a11y:gha": "pa11y http://localhost:4173/ --runner axe -c pa11y.ci.json",
    "a11y:ci": "start-server-and-test preview http-get://localhost:4173 a11y:gha",
    "a11y:check": "yarn run build && yarn run a11y:ci",
    "lint": "node -e \"process.exit(0)\"",
    "format": "node -e \"process.exit(0)\"",
    "typecheck": "tsc -b --noEmit",
    "ci": "yarn lint && yarn typecheck && yarn test && yarn build"
  },
  "dependencies": {
    "@novnc/novnc": "^1.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "winbox": "0.2.82"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.0",
    "happy-dom": "^20.10.1",
    "pa11y": "^9.1.1",
    "postcss": "^8.5.15",
    "start-server-and-test": "^3.0.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "resolutions": {
    "follow-redirects": "^1.16.0"
  },
  "packageManager": "yarn@4.15.0"
}
