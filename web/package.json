{
  "name": "kui-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "a11y": "pa11y http://localhost:4173/ --runner axe",
    "a11y:ci": "start-server-and-test preview http-get://localhost:4173 a11y",
    "a11y:check": "yarn run build && yarn run a11y:ci"
  },
  "dependencies": {
    "@novnc/novnc": "^1.4.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "winbox": "^0.2.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "happy-dom": "^20.8.4",
    "pa11y": "^9.1.1",
    "start-server-and-test": "^2.1.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "packageManager": "yarn@4.13.0"
}
